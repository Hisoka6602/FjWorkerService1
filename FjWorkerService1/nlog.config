<?xml version="1.0" encoding="utf-8"?>
<nlog xmlns="http://www.nlog-project.org/schemas/NLog.xsd"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      autoReload="true"
      throwConfigExceptions="true"
      internalLogLevel="Warn"
      internalLogFile="${basedir}/logs/nlog-internal.log">

	<extensions>
		<add assembly="NLog.Extensions.Logging" />
	</extensions>

	<variable name="logLayout"
			  value="${longdate}|${level:uppercase=true}|${logger}|${threadid}|${message}${onexception:inner=|${exception:format=ToString}}" />

	<targets>
		<!-- Trace -->
		<target xsi:type="AsyncWrapper" name="traceAsync" queueLimit="200000" overflowAction="Discard">
			<target xsi:type="File"
					name="traceFile"
					fileName="${basedir}/logs/Trace/${shortdate}.log"
					archiveEvery="Day"
					archiveNumbering="Date"
					maxArchiveFiles="14"
					encoding="utf-8"
					keepFileOpen="true"
					layout="${var:logLayout}" />
		</target>

		<!-- Debug -->
		<target xsi:type="AsyncWrapper" name="debugAsync" queueLimit="200000" overflowAction="Discard">
			<target xsi:type="File"
					name="debugFile"
					fileName="${basedir}/logs/Debug/${shortdate}.log"
					archiveEvery="Day"
					archiveNumbering="Date"
					maxArchiveFiles="14"
					encoding="utf-8"
					keepFileOpen="true"
					layout="${var:logLayout}" />
		</target>

		<!-- Info -->
		<target xsi:type="AsyncWrapper" name="infoAsync" queueLimit="200000" overflowAction="Discard">
			<target xsi:type="File"
					name="infoFile"
					fileName="${basedir}/logs/Info/${shortdate}.log"
					archiveEvery="Day"
					archiveNumbering="Date"
					maxArchiveFiles="14"
					encoding="utf-8"
					keepFileOpen="true"
					layout="${var:logLayout}" />
		</target>

		<!-- Warn -->
		<target xsi:type="AsyncWrapper" name="warnAsync" queueLimit="200000" overflowAction="Discard">
			<target xsi:type="File"
					name="warnFile"
					fileName="${basedir}/logs/Warn/${shortdate}.log"
					archiveEvery="Day"
					archiveNumbering="Date"
					maxArchiveFiles="30"
					encoding="utf-8"
					keepFileOpen="true"
					layout="${var:logLayout}" />
		</target>

		<!-- Error + Fatal -->
		<target xsi:type="AsyncWrapper" name="errorAsync" queueLimit="200000" overflowAction="Discard">
			<target xsi:type="File"
					name="errorFile"
					fileName="${basedir}/logs/Error/${shortdate}.log"
					archiveEvery="Day"
					archiveNumbering="Date"
					maxArchiveFiles="60"
					encoding="utf-8"
					keepFileOpen="true"
					layout="${var:logLayout}" />
		</target>
	</targets>

	<rules>
		<!-- 按级别单独落文件，使用 maxlevel 防止重复写入 -->
		<logger name="*" minlevel="Trace" maxlevel="Trace" writeTo="traceAsync" final="true" />
		<logger name="*" minlevel="Debug" maxlevel="Debug" writeTo="debugAsync" final="true" />
		<logger name="*" minlevel="Info"  maxlevel="Info"  writeTo="infoAsync"  final="true" />
		<logger name="*" minlevel="Warn"  maxlevel="Warn"  writeTo="warnAsync"  final="true" />
		<logger name="*" minlevel="Error" maxlevel="Fatal" writeTo="errorAsync" />
	</rules>
</nlog>
